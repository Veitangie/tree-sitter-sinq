{
  "name": "tree-sitter-sinq",
  "version": "1.0.0",
  "description": "Tree-sitter grammar for the Sinq DSL",
  "main": "bindings/node",
  "types": "bindings/node",
  "scripts": {
    "build": "tree-sitter generate && node-gyp build",
    "test": "tree-sitter test"
  },
  "dependencies": {
    "node-addon-api": "^8.0.0",
    "node-gyp-build": "^4.8.1"
  },
  "devDependencies": {
    "tree-sitter-cli": "^0.23.0"
  },
  "tree-sitter": [
    {
      "scope": "source.sinq",
      "injection-regex": "sinq"
    }
  ]
}
